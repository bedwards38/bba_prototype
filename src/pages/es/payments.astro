---
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";
import MarchingBandFeesModal from "@components/ui/forms/MarchingBandFeesModal.astro"
import DonationModal from "@components/ui/forms/DonationModal.astro"
import { SITE } from "@data/constants";
import donations from "@images/volunteer/donations.jpg"
import fees from "@images/fees.jpg"

const pageTitle: string = `Pagos | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://bandboosters.org/es/payments",
    "url": "https://bandboosters.org/es/payments",
    "name": "Pagos | Band Boosters",
    "description":
      "¿Quiere donar o pagar las cuotas de la banda de música de su estudiante? ¡Hazlo hoy a través de nuestras opciones de pago en línea, respaldadas por PayPal!",
    "isPartOf": {
      "@type": "WebSite",
      "url": "https://bandboosters.org/es",
      "name": "Band Boosters",
      "description":
        "Una organización sin fines de lucro dirigida por padres cuyo propósito es apoyar todos los programas de banda en las escuelas del distrito.",
    },
    "inLanguage": "es"
  }}
>
    <MainSection
    title="Pagos"
    subTitle="Una forma en que nos gusta hacerlo más fácil para los padres y las personas de la comunidad es brindando opciones de pago directo en nuestro sitio web. Se garantiza que todos los pagos serán seguros y son posibles mediante PayPal."
    btnExists={false}
    />

    <RightSection
    title='Tarifas de la Banda de Música'
    subTitle="¡No más cheques, haga un pago en línea por las tarifas de la banda de música de su estudiante hoy! Podrá proporcionar información sobre su estudiante y especificar el monto que desea pagar. Esto nos permitirá garantizar que su estudiante reciba el crédito adecuado."
    btnExists={true}
    btnTitle="Paga Ahora"
    btnModal={true}
    btnModalToggle="#hs-toggle-between-modals-marching-band-fees-modal"
    includeImg={true}
    single={true}
    imgOne={fees}
    imgOneAlt="Bloques de madera que deletrean 'las tasas'"
    />
    <LeftSection
    title="Hacer una Donación"
    subTitle="Considere hacer una donación para ayudar a los programas de banda del distrito a mejorar el equipo, comprar refrigerios o diseñar programas de conciertos. Todas las donaciones se utilizarán para ayudar a los estudiantes a tener la mejor experiencia posible en los programas de banda. Podrá especificar el monto de su donación y proporcionar una nota de donación personalizada que se compartirá con los estudiantes de la banda."
    btnExists={true}
    btnTitle="Donar Hoy"
    btnModal={true}
    btnModalToggle="#hs-toggle-between-modals-donation-modal"
    includeImg={true}
    img={donations}
    imgAlt="Dinero en un tarro de cristal"
    />


    <MarchingBandFeesModal/>
    <DonationModal />
</MainLayout>
<script>
  import "@preline/collapse/index.js";
  import "@preline/overlay/index.js";
  import "@preline/tooltip/index.js";
</script>
