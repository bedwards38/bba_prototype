---
import MainLayout from "@/layouts/MainLayout.astro";
import MainSection from "@components/ui/blocks/MainSection.astro";
import LeftSection from "@components/ui/blocks/LeftSection.astro";
import RightSection from "@components/ui/blocks/RightSection.astro";

import { SITE } from "@data/constants";
import concessions from "@images/volunteer/concessions.jpg"
import parent from "@images/volunteer/band_parent.jpg"
import volunteer from "@images/volunteer/volunteer.webp"

const pageTitle: string = `Volunteer | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://bandboosters.org/volunteer",
    "url": "https://bandboosters.org/volunteer",
    "name": "Volunteer | Band Boosters",
    "description":
      "Explore different ways you can volunteer to help the district's band programs.",
    "isPartOf": {
      "@type": "WebSite",
      "url": "https://bandboosters.org",
      "name": "Mascotah Band Boosters",
      "description":
        "A parent-led non-profit organization whose purpose is to support all the district's band programs.",
    },
    "inLanguage": "en-US"
  }}
>
    <MainSection
    title="Volunteer Opportunities"
    subTitle="As Band Boosters, we take pride in providing the disctrict's band programs with many services such as fundraisers, snacks, and set-up/tear-down assistance. Our efforts would not be sufficient if this was done alone, so we are always looking for volunteers to help us out. Check out the different opportunities below!"
    btnExists={false}
    />

    <LeftSection
    title='Marching Band "Roadie"'
    subTitle='One of our biggest contributions to the marching band is helping them at their competitions by helping unload the trailer, provide water, etc. Come to the competitions to not only watch your kid perform, but also help them and their bandmates do what they do best. Become a "Roadie" today!"'
    btnExists={true}
    btnTitle="Sign Up"
    btnURL="/#"
    includeImg={true}
    img={parent}
    imgAlt="Parents cheering on their kids"
    />
    <RightSection
    title='Football Concessions Worker'
    subTitle="During high school football season, we host a concessions stand to provide some extra fundraising for the band programs. While you might miss your child's special half-time performance, they will thank you when they are able to get new reeds or sticks for their instrument. Sign up for your shift today!"
    btnExists={true}
    btnTitle="Sign Up"
    btnURL="/#"
    includeImg={true}
    single={true}
    imgOne={concessions}
    imgOneAlt="High School Concessions Stand"
    />
    <LeftSection
    title="Don't See Something You Like?"
    subTitle="That's okay! Make sure to check back here regularly throughout the school year to see what new volunteer opportunities come available."
    btnExists={false}
    includeImg={true}
    img={volunteer}
    imgAlt="Donation box"
    />

</MainLayout>
